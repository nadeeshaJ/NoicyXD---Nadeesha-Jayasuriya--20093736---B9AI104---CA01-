# Copy to repo root:  cp docker/.env.example .env
# Then edit values before:  docker compose up -d --build

# --- Supabase (backend + frontend build) ---
SUPABASE_URL=https://fhpcrtnhqrmjsdcrpqzm.supabase.co
SUPABASE_ANON_KEY=your_publishable_or_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

VITE_SUPABASE_URL=https://fhpcrtnhqrmjsdcrpqzm.supabase.co
VITE_SUPABASE_ANON_KEY=your_publishable_or_anon_key_here

# Public URL users open in the browser (used for CORS and optional frontend API base).
# Examples: http://203.0.113.10  or  https://yourdomain.com
PUBLIC_URL=http://localhost

# Leave empty to call /api on the same host (recommended behind nginx).
# Set only if the API is on a different origin.
VITE_API_BASE_URL=

# --- Backend ---
ML_PROJECT_ROOT=../../
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost,http://127.0.0.1

# Host port for the web UI (nginx). Change if 80 is already in use.
WEB_PORT=80
